# AI Workspace (generated at install time) — ignore everything by default
ai_workspace/**

# Keep framework code inside ai_workspace
!ai_workspace/inspiration_capital/
!ai_workspace/inspiration_capital/scripts/
!ai_workspace/inspiration_capital/scripts/**
!ai_workspace/inspiration_capital/tests/
!ai_workspace/inspiration_capital/tests/**

# Ignore user-generated cards
ai_workspace/inspiration_capital/cards/**

# Ignore pytest cache and pycache
ai_workspace/inspiration_capital/.pytest_cache/
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Temporary files
*.tmp
*.temp
ai_workspace/temp/
*.log
*.bak
*.backup

# Cache
.cache/
*.cache

# Paper - only track final PDF, ignore source files and build artifacts
paper/*.tex
paper/*.bib
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.log
paper/figures/
paper/README.md

