# AI Workspace - ignore contents but keep README files for agent guidance
ai_workspace/*
!ai_workspace/README.md
!ai_workspace/*/
ai_workspace/*/**
!ai_workspace/*/README.md

# Inspiration Capital - keep scripts and tests (they are part of the framework)
!ai_workspace/inspiration_capital/scripts/
!ai_workspace/inspiration_capital/scripts/**
!ai_workspace/inspiration_capital/tests/
!ai_workspace/inspiration_capital/tests/**
# But ignore the actual cards (user-generated content)
ai_workspace/inspiration_capital/cards/*
!ai_workspace/inspiration_capital/cards/.gitkeep
# Ignore pytest cache and pycache
ai_workspace/inspiration_capital/.pytest_cache/
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Temporary files
*.tmp
*.temp
ai_workspace/temp/
*.log
*.bak
*.backup

# Cache
.cache/
*.cache

# Paper - only track final PDF, ignore source files and build artifacts
paper/*.tex
paper/*.bib
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.log
paper/figures/
paper/README.md

